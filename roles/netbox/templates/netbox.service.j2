[Unit]
Description=NetBox WSGI Service
Documentation=https://docs.netbox.dev/
After=network-online.target
Wants=network-online.target

[Service]
Type=notify
User={{ netbox_user }}
Group={{ netbox_group }}
WorkingDirectory={{ netbox_home }}/netbox
ExecStart={{ netbox_venv }}/bin/gunicorn --pid /var/tmp/netbox.pid --config {{ netbox_home }}/gunicorn.py netbox.wsgi
Restart=on-failure
RestartSec=30
PrivateTmp=true

[Install]
WantedBy=multi-user.target